; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="The Cube"
config/description="Spindelngbg 3D multiplayer game. HTTPS/WSS login and matchmaking to cube-production-3d68.up.railway.app. WebRTC P2P sync only. No script execution."
config/version="1.0.0"
run/main_scene="res://scenes/login.tscn"
config/features=PackedStringArray("4.7")

[audio]

buses/default_bus_layout="res://addons/settings_menus/resources/default_bus_layout.tres"

[autoload]

AppIdentity="*res://scripts/app_identity.gd"
Auth="*res://scripts/auth.gd"
CubeGovernance="*res://scripts/cube/cube_governance.gd"
CubeRegistry="*res://scripts/cube/cube_registry.gd"
FirstEntry="*res://scripts/first_entry.gd"
Network="*res://scripts/network.gd"
Profile="*res://scripts/profile.gd"
SceneTransition="*res://scripts/ui/scene_transition.gd"
GlobalChat="*res://scenes/ui/global_chat.tscn"
Settings="*uid://br3e768wqf8sw"
DrawDistance="*res://scripts/rendering/draw_distance_manager.gd"
CrosshairOverlay="*res://scripts/ui/crosshair_overlay.gd"
MouseLook="*res://scripts/camera/mouse_look.gd"
CompetitiveMode="*res://scripts/competitive/competitive_mode.gd"
QuestManager="*res://scripts/story/quest_manager.gd"
InventoryManager="*res://scripts/inventory/inventory_manager.gd"
WeaponManager="*res://scripts/inventory/weapon_manager.gd"
ZoneOwnershipManager="*res://scripts/cube/zone_ownership_manager.gd"
PlayerHouseManager="*res://scripts/cube/player_house_manager.gd"
FurniturePlacementManager="*res://scripts/cube/furniture_placement_manager.gd"
GameTutorialManager="*res://scripts/tutorial/game_tutorial_manager.gd"
PoisonManager="*res://scripts/status/poison_manager.gd"
BuffManager="*res://scripts/status/buff_manager.gd"
ZnoodManager="*res://scripts/znood/znood_manager.gd"
HelpRobotTts="*res://scripts/audio/help_robot_tts.gd"
ZezzlorJailManager="*res://scripts/monsters/zezzlor_jail_manager.gd"
ZezzlorDossierManager="*res://scripts/monsters/zezzlor_dossier_manager.gd"
ZezzlorHuntManager="*res://scripts/monsters/zezzlor_hunt_manager.gd"
GleazerQuestManager="*res://scripts/story/gleazer_quest_manager.gd"
AllmakareDebtManager="*res://scripts/story/allmakare_debt_manager.gd"
MydrilliumEconomyManager="*res://scripts/economy/mydrillium_economy_manager.gd"
FactoryWorkManager="*res://scripts/economy/factory_work_manager.gd"
PhysicsProfile="*res://scripts/physics/physics_profile.gd"
ArrivalQuestManager="*res://scripts/story/arrival_quest_manager.gd"
ArmamentQuestManager="*res://scripts/story/armament_quest_manager.gd"
SpiderQuestManager="*res://scripts/story/spider_quest_manager.gd"
PoiGuideManager="*res://scripts/world/poi_guide_manager.gd"
CriminalBossManager="*res://scripts/story/criminal_boss_manager.gd"
SteamWorks="*res://scripts/platform/steamworks.gd"
SteamAchievements="*res://scripts/platform/steam_achievements.gd"
DragDropSystem="*res://addons/modular_inventory_system/autoload/DragDropSystem.gd"
InputMode="*res://addons/modular_inventory_system/autoload/InputMode.gd"
UICoordinator="*res://addons/modular_inventory_system/autoload/UICoordinator.gd"
UIStateManager="*res://addons/modular_inventory_system/autoload/UIStateManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/settings_menus/plugin.cfg", "res://addons/modular_inventory_system/plugin.cfg", "res://addons/roommate/plugin.cfg")

