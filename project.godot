[physics]

common/physics_ticks_per_second=90
common/max_physics_steps_per_frame=16
common/physics_jitter_fix=0.0
3d/physics_engine="Jolt Physics"
3d/run_on_separate_thread=true
3d/default_gravity=24.0

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
lights_and_shadows/use_physical_light_units=true
lights_and_shadows/directional_shadow/size=512
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=0
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=0
textures/default_filters/anisotropic_filtering_level=0
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
lights_and_shadows/positional_shadow/atlas_size=512

[steam]

initialization/app_data/app_type=0
initialization/app_data/app_id=0
initialization/app_data/demo_id=0
initialization/app_data/playtest_id=0
initialization/app_data/tool_id=0
initialization/processes/initialize_on_startup=false
initialization/processes/embed_callbacks=false
multiplayer_peer/max_channels=4
